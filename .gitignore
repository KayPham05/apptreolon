# ============================================================================
# .gitignore chuẩn cho dự án Flutter — Trello Clone (apptreolon)
# ============================================================================

# ==========================
# Miscellaneous
# ==========================
*.class
*.log
*.pyc
*.swp
*.swo
*.tmp
*.bak
*~
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
Thumbs.db
ehthumbs.db
Desktop.ini
*.stackdump

# ==========================
# IDE — IntelliJ / Android Studio
# ==========================
*.iml
*.ipr
*.iws
.idea/

# ==========================
# IDE — VS Code
# ==========================
# Uncomment dòng dưới nếu không muốn chia sẻ cấu hình VS Code
# .vscode/

# ==========================
# Flutter / Dart / Pub
# ==========================
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/
pubspec.lock

# ==========================
# Generated files (build_runner, freezed, json_serializable, mockito, ...)
# ==========================
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart
*.gr.dart
*.gm.dart

# ==========================
# Environment & Secrets
# ==========================
.env
.env.*
!.env.example
*.jks
*.keystore
*.p12
*.pem
*.key
google-services.json
GoogleService-Info.plist

# ==========================
# Native — Android
# ==========================
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/key.properties

# ==========================
# Native — iOS
# ==========================
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# ==========================
# Native — Windows
# ==========================
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake
**/windows/flutter/ephemeral/

# ==========================
# Native — Linux
# ==========================
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h
**/linux/flutter/generated_plugins.cmake
**/linux/flutter/ephemeral/

# ==========================
# Native — macOS
# ==========================
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral/

# ==========================
# Native — Web
# ==========================
**/web/favicon.png.bak

# ==========================
# Symbolication related
# ==========================
app.*.symbols

# ==========================
# Obfuscation related
# ==========================
app.*.map.json

# ==========================
# Coverage & Test
# ==========================
coverage/
*.lcov
test-results/

# ==========================
# Fastlane (CI/CD)
# ==========================
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# ==========================
# FVM (Flutter Version Management)
# ==========================
.fvm/flutter_sdk
.fvm/fvm_config.json
.fvmrc

# ==========================
# Gemini / AI Agent
# ==========================
.gemini/
.agent/
.agents/
